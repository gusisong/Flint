{
  "name": "flint-electron-app",
  "version": "0.1.0",
  "private": true,
  "description": "Flint Electron + Vue skeleton",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build:renderer": "vite build",
    "start": "electron .",
    "test": "vitest run"
  },
  "dependencies": {
    "vue": "^3.5.13",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
